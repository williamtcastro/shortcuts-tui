# Shortcuts TUI Configuration Example

# Define your custom tabs/views
views:
  - name: "Aliases"
    type: "alias"
    dirs: 
      - "$HOME/dotfiles/scripts"
  - name: "Docs"
    type: "doc"
    dirs:
      - "$HOME/dotfiles/docs"
      - "./docs"

# Pagination style: "numeric" (e.g., 1/3) or "dots" (e.g., •●•)
pagination: "dots"

# Automatically clear the terminal before running a shortcut
auto_clear: false

# Automatically exit the TUI after running a shortcut or copying a command
auto_exit: false

# Customize your TUI colors (Catppuccin Mocha defaults shown)
theme:
  primary: "#a6e3a1"   # Green (Tabs/Headers)
  secondary: "#6c7086" # Overlay0 (Dimmed text)
  text: "#cdd6f4"      # Text (Default text)
  accent: "#f9e2af"    # Yellow (Active cursor)
  mauve: "#cba6f7"     # Mauve (Descriptions)
  flamingo: "#f2cdcd"  # Flamingo (Search bar)
